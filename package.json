{
  "name": "defi-portfolio-dashboard",
  "private": true,
  "scripts": {
    "lint": "npm --prefix web run lint",
    "format": "npx --prefix web prettier --write \"web/src/**/*.{js,ts,jsx,tsx,json,css,md}\"",
    "prepare": "husky install"
  },
  "devDependencies": {
    "husky": "^8.0.0",
    "lint-staged": "^15.2.0"
  },
  "lint-staged": {
    "web/src/**/*.{ts,tsx,js,jsx,json,css,md}": [
      "npx --prefix web prettier --write",
      "npx --prefix web eslint --fix"
    ]
  }
}
